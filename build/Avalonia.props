<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <AvaloniaXamlCompilerBackend Condition="'$(DockUseXamlSourceGenerator)' == 'true' and '$(AvaloniaXamlCompilerBackend)' == ''">SourceGen</AvaloniaXamlCompilerBackend>
    <AvaloniaSourceGenCompilerEnabled Condition="'$(DockUseXamlSourceGenerator)' == 'true' and '$(AvaloniaSourceGenCompilerEnabled)' == ''">true</AvaloniaSourceGenCompilerEnabled>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="XamlToCSharpGenerator" Condition="'$(DockUseXamlSourceGenerator)' == 'true'" />
  </ItemGroup>
  <ItemGroup Condition="'$(DockUseXamlSourceGenerator)' == 'true'">
    <Using Include="XamlToCSharpGenerator.Runtime" />
  </ItemGroup>
</Project>
