<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Dock.Avalonia.Controls"
                    xmlns:dmc="using:Dock.Model.Controls"
                    x:DataType="dmc:IProportionalDock"
                    x:CompileBindings="True">
  <Design.PreviewWith>
    <FlatProportionalDockControl Width="300" Height="300" />
  </Design.PreviewWith>

  <ControlTheme x:Key="{x:Type FlatProportionalDockControl}" TargetType="FlatProportionalDockControl">

    <Setter Property="(AutomationProperties.AutomationId)" Value="{Binding Id}" />
    <Setter Property="(AutomationProperties.Name)" Value="{Binding Title}" />

    <Setter Property="(DockProperties.IsDragEnabled)" Value="{Binding CanDrag}" />
    <Setter Property="(DockProperties.IsDropEnabled)" Value="{Binding CanDrop}" />
    <Setter Property="(DockProperties.DockGroup)" Value="{Binding DockGroup}" />

    <Setter Property="Template">
      <ControlTemplate>
        <DockableControl TrackingMode="Visible">
          <controls:FlatProportionalDockPanel x:Name="PART_Panel"
                                              Dock="{Binding}"
                                              Background="Transparent"
                                              SplitterThickness="{DynamicResource DockFlatSplitterThickness}"
                                              MinimumProportionSize="{DynamicResource DockFlatMinimumProportionSize}" />
        </DockableControl>
      </ControlTemplate>
    </Setter>

  </ControlTheme>

</ResourceDictionary>
