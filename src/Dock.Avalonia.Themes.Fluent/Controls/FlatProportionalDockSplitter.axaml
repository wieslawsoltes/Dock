<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:CompileBindings="True">
  <Design.PreviewWith>
    <FlatProportionalDockSplitter Width="300" Height="4" />
  </Design.PreviewWith>

  <ControlTheme x:Key="{x:Type FlatProportionalDockSplitter}" TargetType="FlatProportionalDockSplitter">

    <Setter Property="Background" Value="{DynamicResource DockSplitterIdleBrush}" />

    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}" />
      </ControlTemplate>
    </Setter>

    <Style Selector="^:pointerover">
      <Setter Property="Background" Value="{DynamicResource DockSplitterHoverBrush}" />
    </Style>

    <Style Selector="^:preview">
      <Setter Property="Background" Value="{DynamicResource DockSplitterDragBrush}" />
    </Style>

  </ControlTheme>

</ResourceDictionary>
