<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Dock.Avalonia.Controls"
        xmlns:fluent="using:Dock.Avalonia.Themes.Fluent"
        x:Class="Dock.Avalonia.Themes.Fluent.DockFluentFlatTheme">
  <fluent:DockFluentTheme />
  <StyleInclude Source="/Controls/FlatDockTarget.axaml" />

  <Style Selector="controls|DockControl">
    <Setter Property="PresentationMode" Value="Flat" />
  </Style>
</Styles>
