<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:CompileBindings="True">
  <Design.PreviewWith>
    <FlatProportionalSplitter Width="300" Height="4" />
  </Design.PreviewWith>

  <Styles.Resources>
    <ResourceDictionary>
      <ControlTheme x:Key="{x:Type FlatProportionalSplitter}" TargetType="FlatProportionalSplitter">
        <Setter Property="Background" Value="{DynamicResource FlatProportionalSplitterIdleBrush}" />

        <Setter Property="Template">
          <ControlTemplate>
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" />
          </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
          <Setter Property="Background" Value="{DynamicResource FlatProportionalSplitterHoverBrush}" />
        </Style>

        <Style Selector="^:preview">
          <Setter Property="Background" Value="{DynamicResource FlatProportionalSplitterDragBrush}" />
        </Style>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>
</Styles>
