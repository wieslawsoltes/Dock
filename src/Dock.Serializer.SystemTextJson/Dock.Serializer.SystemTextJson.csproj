<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net6.0;net8.0;net10.0</TargetFrameworks>
    <OutputType>Library</OutputType>
    <DocumentationFile>bin\$(Configuration)\$(TargetFramework)\$(AssemblyName).xml</DocumentationFile>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Dock.Serializer.SystemTextJson</PackageId>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);AddDockSourceGeneratorAnalyzerToPackage</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <Import Project="..\..\build\SignAssembly.props" />
  <Import Project="..\..\build\SourceLink.props" />
  <Import Project="..\..\build\System.Text.Json.props" />
  <Import Project="..\..\build\ReferenceAssemblies.props" />

  <ItemGroup>
    <ProjectReference Include="..\Dock.Model\Dock.Model.csproj" />
    <ProjectReference Include="..\Dock.Serializer.SystemTextJson.Generators\Dock.Serializer.SystemTextJson.Generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      PrivateAssets="all"
                      SetTargetFramework="TargetFramework=netstandard2.0" />
  </ItemGroup>

  <Target Name="AddDockSourceGeneratorAnalyzerToPackage"
          Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(MSBuildProjectDirectory)\..\Dock.Serializer.SystemTextJson.Generators\bin\$(Configuration)\netstandard2.0\Dock.Serializer.SystemTextJson.Generators.dll"
                              Condition="Exists('$(MSBuildProjectDirectory)\..\Dock.Serializer.SystemTextJson.Generators\bin\$(Configuration)\netstandard2.0\Dock.Serializer.SystemTextJson.Generators.dll')">
        <PackagePath>analyzers/dotnet/cs/</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>

</Project>
